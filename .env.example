# ─── Supabase ─────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com, then find these in:
#   Project Settings → API
#
# SUPABASE_URL            → Project URL
# SUPABASE_ANON_KEY       → anon / public key  (safe for browsers)
# SUPABASE_SERVICE_ROLE_KEY → service_role key (server-only, never expose to browser)
#
# Run the SQL migrations in supabase/migrations/ via the Supabase SQL editor.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase (client-side — exposed to browser via Vite, use anon key only)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Social OAuth (optional) ──────────────────────────────────────────────────
# Enable Google and/or GitHub sign-in in the Supabase Dashboard:
#   Authentication → Providers → Google / GitHub
#
# Google OAuth:
#   1. Go to https://console.cloud.google.com → APIs & Services → Credentials
#   2. Create an OAuth 2.0 Client ID (Web application)
#   3. Add your Supabase callback URL as an Authorized redirect URI:
#      https://your-project.supabase.co/auth/v1/callback
#   4. Copy Client ID + Secret into Supabase Dashboard → Auth → Providers → Google
#
# GitHub OAuth:
#   1. Go to https://github.com/settings/developers → New OAuth App
#   2. Set Authorization callback URL to:
#      https://your-project.supabase.co/auth/v1/callback
#   3. Copy Client ID + Secret into Supabase Dashboard → Auth → Providers → GitHub
#
# Heroku: also add your Heroku app URL to Supabase Auth → URL Configuration → Redirect URLs:
#   https://your-app.herokuapp.com

# ─── Gemini API Keys ──────────────────────────────────────────────────────────
# Supports multiple keys (GEMINI_API_KEY_1, GEMINI_API_KEY_2, etc.)
# Get free keys at https://aistudio.google.com/app/apikey
GEMINI_API_KEY_1=AIza...
GEMINI_API_KEY_2=AIza...

# ─── Groq API Keys ────────────────────────────────────────────────────────────
# Supports multiple keys (GROQ_API_KEY_1, GROQ_API_KEY_2, etc.)
# Get free keys at https://console.groq.com — very generous free tier
# (14,400 req/day, 6,000 tokens/min per key)
GROQ_API_KEY_1=gsk_...
GROQ_API_KEY_2=gsk_...

# ─── OpenRouter API Keys ──────────────────────────────────────────────────────
# Supports multiple keys (OPENROUTER_API_KEY_1, OPENROUTER_API_KEY_2, etc.)
# Get keys at https://openrouter.ai/keys — free models need no credits
OPENROUTER_API_KEY_1=sk-or-...
OPENROUTER_API_KEY_2=sk-or-...

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── Owner access ─────────────────────────────────────────────────────────────
# The scraper is restricted to users with is_owner=true in the database.
# To grant access, run this in the Supabase SQL editor (replace the email):
#   UPDATE public.users SET is_owner = true WHERE email = 'you@example.com';
