# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI API Keys (supports multiple: OPENAI_API_KEY_1, OPENAI_API_KEY_2, etc.)
OPENAI_API_KEY_1=sk-...
OPENAI_API_KEY_2=sk-...

# OpenRouter API Keys (supports multiple: OPENROUTER_API_KEY_1, OPENROUTER_API_KEY_2, etc.)
OPENROUTER_API_KEY_1=sk-or-...
OPENROUTER_API_KEY_2=sk-or-...

# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173
