# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase (client-side — exposed to browser via Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Gemini API Keys (supports multiple: GEMINI_API_KEY_1, GEMINI_API_KEY_2, etc.)
# Get free keys at https://aistudio.google.com/app/apikey
GEMINI_API_KEY_1=AIza...
GEMINI_API_KEY_2=AIza...

# OpenRouter API Keys (supports multiple: OPENROUTER_API_KEY_1, OPENROUTER_API_KEY_2, etc.)
# Get keys at https://openrouter.ai/keys — free models need no credits
OPENROUTER_API_KEY_1=sk-or-...
OPENROUTER_API_KEY_2=sk-or-...

# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173
